generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp")]
}

// ----------------------------------------------------
// ENUMERATOR
// ----------------------------------------------------

enum PermissionGrup {
  dashboard
  user
  user_roles
  user_roles_permissions
  siswa
  prestasi
  kegiatan
  pengumuman
  carousel
  foto
  sosmed
  Kelulusan
  Nilai
}

enum Tingkatan {
  PG_TK
  SD_KELAS_RENDAH
  SD_KELAS_TINGGI
  SMP
  SMA_MIPA
  SMA_IPS
}

// ✅ BARU: Enum untuk kelas kelulusan SMA
enum KelasKelulusan {
  XII_MIPA
  XII_IPS
}

enum JenisKelamin {
  L
  P
}

enum StatusSiswa {
  AKTIF
  TIDAK_AKTIF
}

enum Semester {
  GANJIL
  GENAP
}

enum SocialMediaPlatform {
  Facebook
  Instagram
  Youtube
  Tiktok
  Website
}

enum SchoolLevel {
  PGTK
  SD
  SMP
  SMA
}

// ----------------------------------------------------
// MODEL UTAMA (MASTER DATA)
// ----------------------------------------------------

model role {
  role_id   Int    @id @default(autoincrement())
  nama_role String @unique(map: "role_nama_role_unique") @db.VarChar(50)

  users           users[]
  role_permission role_permission[]
}

model permission {
  permission_id   Int             @id @default(autoincrement())
  nama_permission String          @unique(map: "permission_nama_permission_unique") @db.VarChar(50)
  grup            PermissionGrup?

  role_permission role_permission[]
}

model role_permission {
  role_id       Int
  permission_id Int

  role       role       @relation(fields: [role_id], references: [role_id], onDelete: Cascade, onUpdate: Cascade, map: "role_permission_ibfk_1")
  permission permission @relation(fields: [permission_id], references: [permission_id], onDelete: Cascade, onUpdate: Cascade, map: "role_permission_ibfk_2")

  @@id([role_id, permission_id])
}

model users {
  user_id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  username       String    @unique(map: "users_username_unique") @db.VarChar(100)
  email          String    @unique(map: "users_email_unique") @db.VarChar(150)
  password_hash  String    @db.VarChar(255)
  nama_lengkap   String    @db.VarChar(255)
  role_id        Int
  jabatan        String?   @db.VarChar(100)
  created_at     DateTime? @default(now()) @db.Timestamp(3)
  updated_at     DateTime? @default(now()) @updatedAt @db.Timestamp(3)
  login_terakhir DateTime? @db.Timestamp(3)
  nilaiPenulis subject_grades[] @relation("NilaiPenulis")
  nilaiEditor  subject_grades[] @relation("NilaiEditor")
  role role @relation(fields: [role_id], references: [role_id], onDelete: Cascade, onUpdate: Cascade, map: "users_role_id_fkey")
  prestasiPenulis    prestasi[]     @relation("PrestasiPenulis")
  prestasiEditor     prestasi[]     @relation("PrestasiEditor")
  kegiatanPenulis    kegiatan[]     @relation("KegiatanPenulis")
  kegiatanEditor     kegiatan[]     @relation("KegiatanEditor")
  pengumumanPenulis  pengumuman[]   @relation("PengumumanPenulis")
  pengumumanEditor   pengumuman[]   @relation("PengumumanEditor")
  carouselPenulis    carousel[]     @relation("CarouselPenulis")
  carouselEditor     carousel[]     @relation("CarouselEditor")
  SocialMediaPenulis social_media[] @relation("SocialMediaPenulis")
  SocialMediaeditor  social_media[] @relation("SocialMediaEditor")
  kelulusanPenulis   kelulusan[]    @relation("KelulusanPenulis")
  kelulusanEditor    kelulusan[]    @relation("KelulusanEditor")
  gradConfigPenulis graduation_config[] @relation("GradConfigPenulis")
  gradConfigEditor  graduation_config[] @relation("GradConfigEditor")

  @@index([role_id], map: "users_role_id_index")
}

model jenjang {
  jenjang_id   String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nama_jenjang String @unique(map: "jenjang_nama_jenjang_unique") @db.VarChar(50)
  kode_jenjang String @unique(map: "jenjang_kode_jenjang_unique") @db.VarChar(10)
  subjectGrades subject_grades[]
  Kelulusan     kelulusan[]
  graduationConfigs graduation_config[]
  pengumuman         pengumuman[]
  prestasi           prestasi[]
  kegiatan           kegiatan[]
  carousels          carousel[]
  prestasiJenjangs   prestasi_jenjang[]
  kegiatanJenjangs   kegiatan_jenjang[]
  pengumumanJenjangs pengumuman_jenjang[]
}

model prestasi {
  prestasi_id       String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  judul             String    @db.VarChar(255)
  deskripsi         String?   @db.Text
  konten            String    @db.Text
  path_gambar       String?   @db.VarChar(255)
  tanggal_publikasi DateTime  @db.Timestamp(3)
  is_published      Boolean?  @default(true)
  is_featured       Boolean?  @default(true)
  created_at        DateTime? @default(now()) @db.Timestamp(3)
  updated_at        DateTime  @default(now()) @updatedAt @db.Timestamp(3)

  jenjang_relasi prestasi_jenjang[]

  penulis_user_id   String   @db.Uuid
  editor_user_id    String?  @db.Uuid
  jenjangJenjang_id String?  @db.Uuid

  penulis users    @relation("PrestasiPenulis", fields: [penulis_user_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade, map: "prestasi_penulis_fkey")
  editor  users?   @relation("PrestasiEditor", fields: [editor_user_id], references: [user_id], onDelete: SetNull, onUpdate: Cascade, map: "prestasi_editor_fkey")
  jenjang jenjang? @relation(fields: [jenjangJenjang_id], references: [jenjang_id])

  @@index([penulis_user_id], map: "prestasi_penulis_user_id_index")
  @@index([editor_user_id], map: "prestasi_editor_user_id_index")
}

model kegiatan {
  kegiatan_id       String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  judul             String    @db.VarChar(255)
  deskripsi         String?   @db.Text
  konten            String    @db.Text
  path_gambar       String?   @db.VarChar(255)
  tanggal_publikasi DateTime  @db.Timestamp(3)
  is_published      Boolean?  @default(true)
  is_featured       Boolean?  @default(true)
  created_at        DateTime? @default(now()) @db.Timestamp(3)
  updated_at        DateTime  @default(now()) @updatedAt @db.Timestamp(3)

  jenjang_relasi kegiatan_jenjang[]

  penulis_user_id   String   @db.Uuid
  editor_user_id    String?  @db.Uuid
  jenjangJenjang_id String?  @db.Uuid

  penulis users    @relation("KegiatanPenulis", fields: [penulis_user_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade, map: "kegiatan_penulis_fkey")
  editor  users?   @relation("KegiatanEditor", fields: [editor_user_id], references: [user_id], onDelete: SetNull, onUpdate: Cascade, map: "kegiatan_editor_fkey")
  jenjang jenjang? @relation(fields: [jenjangJenjang_id], references: [jenjang_id])

  @@index([penulis_user_id], map: "kegiatan_penulis_user_id_index")
  @@index([editor_user_id], map: "kegiatan_editor_user_id_index")
}

model pengumuman {
  pengumuman_id     String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  judul             String    @db.VarChar(255)
  deskripsi         String?   @db.Text
  konten            String    @db.Text
  tanggal_publikasi DateTime  @db.Timestamp(3)
  is_published      Boolean?  @default(true)
  is_featured       Boolean?  @default(true)
  created_at        DateTime? @default(now()) @db.Timestamp(3)
  updated_at        DateTime  @default(now()) @updatedAt @db.Timestamp(3)

  jenjang_relasi pengumuman_jenjang[]

  jenjang_id        String?  @db.Uuid
  penulis_user_id   String   @db.Uuid
  editor_user_id    String?  @db.Uuid
  jenjangJenjang_id String?  @db.Uuid

  penulis users    @relation("PengumumanPenulis", fields: [penulis_user_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade, map: "pengumuman_penulis_fkey")
  editor  users?   @relation("PengumumanEditor", fields: [editor_user_id], references: [user_id], onDelete: SetNull, onUpdate: Cascade, map: "pengumuman_editor_fkey")
  jenjang jenjang? @relation(fields: [jenjangJenjang_id], references: [jenjang_id])

  @@index([penulis_user_id], map: "pengumuman_penulis_user_id_index")
  @@index([editor_user_id], map: "pengumuman_editor_user_id_index")
}

// ----------------------------------------------------
// JUNCTION TABLES (Tabel Perantara M:M)
// ----------------------------------------------------

model prestasi_jenjang {
  prestasi_id String @db.Uuid
  jenjang_id  String @db.Uuid

  prestasi prestasi @relation(fields: [prestasi_id], references: [prestasi_id], onDelete: Cascade, map: "prestasi_jenjang_ibfk_1")
  jenjang  jenjang  @relation(fields: [jenjang_id], references: [jenjang_id], onDelete: Cascade, map: "prestasi_jenjang_ibfk_2")

  @@id([prestasi_id, jenjang_id])
  @@index([jenjang_id], map: "prestasi_jenjang_jenjang_id_index")
}

model kegiatan_jenjang {
  kegiatan_id String @db.Uuid
  jenjang_id  String @db.Uuid

  kegiatan kegiatan @relation(fields: [kegiatan_id], references: [kegiatan_id], onDelete: Cascade, map: "kegiatan_jenjang_ibfk_1")
  jenjang  jenjang  @relation(fields: [jenjang_id], references: [jenjang_id], onDelete: Cascade, map: "kegiatan_jenjang_ibfk_2")

  @@id([kegiatan_id, jenjang_id])
  @@index([jenjang_id], map: "kegiatan_jenjang_jenjang_id_index")
}

model pengumuman_jenjang {
  pengumuman_id String @db.Uuid
  jenjang_id    String @db.Uuid

  pengumuman pengumuman @relation(fields: [pengumuman_id], references: [pengumuman_id], onDelete: Cascade, map: "pengumuman_jenjang_ibfk_1")
  jenjang    jenjang    @relation(fields: [jenjang_id], references: [jenjang_id], onDelete: Cascade, map: "pengumuman_jenjang_ibfk_2")

  @@id([pengumuman_id, jenjang_id])
  @@index([jenjang_id], map: "pengumuman_jenjang_jenjang_id_index")
}

// ----------------------------------------------------
// GALLERIES & CAROUSEL
// ----------------------------------------------------

model galleries {
  pic_id    String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  path_file String  @db.VarChar(255)
  alt       String? @db.VarChar(255)

  created_at DateTime? @default(now()) @db.Timestamp(3)
  updated_at DateTime? @default(now()) @updatedAt @db.Timestamp(3)
}

model carousel {
  carousel_id       String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  judul             String    @db.VarChar(255)
  urutan            Int       @unique
  konten            String    @db.Text
  path_gambar       String    @db.VarChar(255)
  tanggal_publikasi DateTime  @db.Timestamp(3)
  is_published      Boolean?  @default(true)
  is_featured       Boolean?  @default(true)
  created_at        DateTime? @default(now()) @db.Timestamp(3)
  updated_at        DateTime  @default(now()) @updatedAt @db.Timestamp(3)

  jenjang_id      String? @db.Uuid
  penulis_user_id String  @db.Uuid
  editor_user_id  String? @db.Uuid

  jenjang jenjang? @relation(fields: [jenjang_id], references: [jenjang_id], onDelete: SetNull, onUpdate: Cascade, map: "carousel_jenjang_id_fkey")
  penulis users    @relation("CarouselPenulis", fields: [penulis_user_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade, map: "carousel_penulis_fkey")
  editor  users?   @relation("CarouselEditor", fields: [editor_user_id], references: [user_id], onDelete: SetNull, onUpdate: Cascade, map: "carousel_editor_fkey")

  @@index([jenjang_id], map: "carousel_jenjang_id_index")
  @@index([penulis_user_id], map: "carousel_penulis_user_id_index")
  @@index([editor_user_id], map: "carousel_editor_user_id_index")
  @@index([urutan], map: "carousel_urutan_index")
}

// ----------------------------------------------------
// SISWA (Legacy Model)
// ----------------------------------------------------

model Siswa {
  id           String       @id @default(cuid())
  no           Int          @unique @default(autoincrement())
  nama         String
  nisn         String       @unique
  alamat       String
  tanggalLahir DateTime
  jenisKelamin JenisKelamin
  kelas        String
  telepon      String?
  email        String?      @unique
  status       StatusSiswa  @default(AKTIF)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  orangTua OrangTua[]
  nilai    Nilai[]

  @@map("siswa")
}

model OrangTua {
  id             String   @id @default(cuid())
  siswaId        String
  namaAyah       String
  namaIbu        String
  pekerjaanAyah  String?
  pekerjaanIbu   String?
  teleponAyah    String?
  teleponIbu     String?
  alamatOrangTua String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  siswa Siswa @relation(fields: [siswaId], references: [id], onDelete: Cascade)

  @@map("orang_tua")
}

model Nilai {
  id            String   @id @default(cuid())
  siswaId       String
  mataPelajaran String
  semester      Semester
  tahunAjaran   String
  nilaiHarian   Float    @default(0)
  nilaiUTS      Float    @default(0)
  nilaiUAS      Float    @default(0)
  nilaiAkhir    Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  siswa Siswa @relation(fields: [siswaId], references: [id], onDelete: Cascade)

  @@map("nilai")
}

// ----------------------------------------------------
// SOCIAL MEDIA
// ----------------------------------------------------

model social_media {
  social_media_id String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  platform        SocialMediaPlatform
  username        String              @db.VarChar(100)
  url             String              @db.VarChar(255)
  level           SchoolLevel
  followers       String?             @db.VarChar(50)
  is_active       Boolean?            @default(true)
  urutan          Int?
  created_at      DateTime?           @default(now()) @db.Timestamp(3)
  updated_at      DateTime?           @default(now()) @updatedAt @db.Timestamp(3)

  penulis_user_id String  @db.Uuid
  editor_user_id  String? @db.Uuid

  penulis users  @relation("SocialMediaPenulis", fields: [penulis_user_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade)
  editor  users? @relation("SocialMediaEditor", fields: [editor_user_id], references: [user_id], onDelete: SetNull, onUpdate: Cascade)

  @@index([penulis_user_id])
  @@index([editor_user_id])
  @@index([level])
  @@unique([platform, level])
}

// ----------------------------------------------------
// KELULUSAN (✅ UPDATED)
// ----------------------------------------------------

model kelulusan {
  kelulusan_id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  // Data Siswa
  nomor_siswa  String    @unique @db.VarChar(50)
  nama_siswa   String    @db.VarChar(255)
  tempat_lahir String?   @db.VarChar(100)
  tanggal_lahir DateTime? @db.Date

  // ✅ BARU: Kelas XII MIPA atau XII IPS
  kelas KelasKelulusan

  // Status & Detail
  status_lulus    Boolean @default(false)
  nilai_rata_rata Float?
  keterangan      String? @db.Text

  // ✅ BARU: Tanggal & jam mulai bisa diakses publik
  tanggal_akses DateTime? @db.Timestamp(3)

  // File Pendukung
  path_skhun String? @db.VarChar(255)

  // Metadata & Audit
  is_active    Boolean?  @default(true)
  tahun_ajaran String    @db.VarChar(20)
  created_at   DateTime? @default(now()) @db.Timestamp(3)
  updated_at   DateTime  @default(now()) @updatedAt @db.Timestamp(3)

  // Foreign Keys
  jenjang_id      String  @db.Uuid
  penulis_user_id String  @db.Uuid
  editor_user_id  String? @db.Uuid

  // Relasi
  jenjang jenjang @relation(fields: [jenjang_id], references: [jenjang_id], onDelete: Cascade)
  penulis users   @relation("KelulusanPenulis", fields: [penulis_user_id], references: [user_id], onDelete: Cascade)
  editor  users?  @relation("KelulusanEditor", fields: [editor_user_id], references: [user_id], onDelete: SetNull)

  @@index([jenjang_id])
  @@index([nomor_siswa])
  @@index([tahun_ajaran])
  @@index([kelas])
  @@index([tanggal_akses])
}

// ----------------------------------------------------
// SUBJECT GRADES (RAPOR)
// ----------------------------------------------------

model subject_grades {
  grade_id     String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tahun_ajaran String @db.VarChar(20)
  semester     String @db.VarChar(10)
  status       String @default("Draft") @db.VarChar(20)
  nama_siswa   String @db.VarChar(255)
  nilai_json   Json
  catatan      String? @db.Text

  student_user_id String @db.VarChar(255)

  jenjang_id String  @db.Uuid
  jenjang    jenjang @relation(fields: [jenjang_id], references: [jenjang_id], onDelete: Cascade)

  created_at DateTime? @default(now()) @db.Timestamp(3)
  updated_at DateTime  @default(now()) @updatedAt @db.Timestamp(3)

  penulis_user_id String  @db.Uuid
  editor_user_id  String? @db.Uuid

  penulis users  @relation("NilaiPenulis", fields: [penulis_user_id], references: [user_id], onDelete: Cascade)
  editor  users? @relation("NilaiEditor", fields: [editor_user_id], references: [user_id], onDelete: SetNull)

  @@index([student_user_id])
  @@index([jenjang_id])
  @@index([tahun_ajaran])
  @@unique([student_user_id, tahun_ajaran, semester], map: "unique_rapor_siswa")
}

// ----------------------------------------------------
// PENDAFTARAN
// ----------------------------------------------------

model Pendaftaran {
  id String @id @default(uuid())

  // Data Siswa
  namaSiswa          String
  kelas              String
  tempatLahir        String
  tanggalLahir       DateTime
  jenisKelamin       String
  belajarAgama       String
  golonganDarah      String?
  anakKe             Int
  jumlahSaudara      Int
  status             String
  alamatSiswa        String
  telpSiswa          String
  tinggalBersama     String
  lulusanDariSekolah String?
  nisn               String?

  // Ijazah (optional untuk SMP/SMA)
  nomorIjazah       String?
  tglIjazah         DateTime?
  tahunIjazah       Int?
  jumlahNilaiUS     Float?
  pindahanDariSekolah String?
  alamatSekolahAsal String?
  emailOrangtua     String

  // Data Ayah
  namaAyah         String
  tempatLahirAyah  String
  tanggalLahirAyah DateTime
  agamaAyah        String
  pendidikanAyah   String
  alamatAyah       String
  pekerjaanAyah    String
  telpAyah         String

  // Data Ibu
  namaIbu         String
  tempatLahirIbu  String
  tanggalLahirIbu DateTime
  agamaIbu        String
  pendidikanIbu   String
  alamatIbu       String
  pekerjaanIbu    String
  telpIbu         String

  // File paths
  akteLahirUrl     String
  kartuKeluargaUrl String
  buktiTransferUrl String

  // Metadata
  statusPendaftaran String   @default("pending")
  noPendaftaran     String   @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("pendaftaran")
}

// ----------------------------------------------------
// MATA PELAJARAN
// ----------------------------------------------------

model MataPelajaran {
  id        String    @id @default(cuid())
  kode      String    @unique
  nama      String
  tingkatan Tingkatan
  urutan    Int
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tingkatan, urutan])
  @@index([tingkatan])
  @@index([isActive])
  @@map("mata_pelajaran")
}
// Tambahkan ke schema.prisma yang sudah ada

model graduation_config {
  config_id     String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  jenjang_id    String         @db.Uuid
  tahun_ajaran  String         @db.VarChar(20)
  kelas         KelasKelulusan // XII_MIPA atau XII_IPS

  // Kapan pengumuman mulai bisa diakses publik
  tanggal_akses DateTime       @db.Timestamp(3)

  // Pesan yang tampil di banner halaman client
  pesan_banner  String?        @db.Text

  is_active     Boolean        @default(true)
  created_at    DateTime?      @default(now()) @db.Timestamp(3)
  updated_at    DateTime       @default(now()) @updatedAt @db.Timestamp(3)

  penulis_user_id String        @db.Uuid
  editor_user_id  String?       @db.Uuid

  jenjang jenjang @relation(fields: [jenjang_id], references: [jenjang_id], onDelete: Cascade)
  penulis users   @relation("GradConfigPenulis", fields: [penulis_user_id], references: [user_id], onDelete: Cascade)
  editor  users?  @relation("GradConfigEditor",  fields: [editor_user_id],  references: [user_id], onDelete: SetNull)

  @@unique([jenjang_id, tahun_ajaran, kelas], map: "unique_grad_config")
  @@index([jenjang_id])
  @@index([tahun_ajaran])
  @@index([kelas])
  @@map("graduation_config")
}

